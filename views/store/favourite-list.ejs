<%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/nav') %>

  <main class="container mx-auto bg-white shadow-lg rounded-lg p-8 mt-10 max-w-6xl">
    
    <h2 class="text-3xl text-red-500 font-bold text-center mb-6">
      My Favourite Homes 
    </h2>

    <div class="flex flex-wrap justify-center gap-6">

      <% if (favouriteHomes && favouriteHomes.length > 0) { %>

        <% favouriteHomes.forEach(home => { %>

          <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition duration-300 w-64">

            <!-- IMAGE -->
            <img src="<%= home.photoUrl %>" 
                 alt="<%= home.houseName %>" 
                 class="w-full h-48 object-cover">

            <div class="p-4">

              <!-- NAME -->
              <h3 class="text-lg font-semibold text-gray-800 mb-2">
                <%= home.houseName %>
              </h3>

              <!-- LOCATION -->
              <p class="text-gray-600 mb-2">
                📍 <%= home.location %>
              </p>

              <!-- PRICE + RATING -->
              <div class="flex justify-between items-center mb-3">

                <span class="text-lg font-bold text-red-500">
                  ₹ <%= home.price %> / night
                </span>

                <span class="text-gray-700">
                  ⭐ <%= home.rating %>
                </span>
              </div>

                <div class="flex gap-5">
                 <!-- REMOVE -->
                  <form action="/favourites/remove/<%= home._id %>" method="POST" class="w-1/2">
                  <button class="w-full bg-red-400 text-red-600 text-sm py-1 rounded-md hover:bg-red-200 transition">
                   Remove
                   </button>
                </form>
             </div>

            </div>
          </div>

        <% }) %>

      <% } else { %>

        <!-- EMPTY STATE -->
        <div class="text-center w-full">
          <p class="text-gray-500 text-lg mb-4">
            No favourites yet
          </p>

          <a href="/homes" 
             class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 transition">
             Browse Homes
          </a>
        </div>

      <% } %>

    </div>

  </main>
</body>
</html>