<%- include('../partials/head') %>
</head>
<body>

  <%- include('../partials/nav') %>

  <main class="container mx-auto mt-8 p-8 bg-white rounded-lg shadow-md">

    <h1 class="text-3xl font-bold mb-6 text-center text-gray-800">
      <%= editing ? "Edit" : "Register" %> Your Home on AirBnB
    </h1>

   <form action="/host/<%= editing ? 'edit-home' : 'add-home' %>" method="POST">

      <% if (editing) { %>
        <input type="hidden" name="id" value="<%= home._id %>" />
      <% } %>

      <input
        type="text"
        name="houseName"
        value="<%= editing ? home.houseName : '' %>"
        placeholder="Enter your House Name"
        required
        class="w-full px-4 py-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
      />

      <input
        type="number"
        name="price"
        value="<%= editing ? home.price : '' %>"
        placeholder="Price Per Night"
        required
        class="w-full px-4 py-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
      />

      <input
        type="text"
        name="location"
        value="<%= editing ? home.location : '' %>"
        placeholder="Location"
        required
        class="w-full px-4 py-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
      />

      <input
        type="number"
        name="rating"
        value="<%= editing ? home.rating : '' %>"
        placeholder="Rating"
        required
        class="w-full px-4 py-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
      />

      <input
        type="text"
        name="photoUrl"
        value="<%= editing ? home.photoUrl : '' %>"
        placeholder="Enter Photo URL"
        required
        class="w-full px-4 py-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
      />

      <!-- ✅ NEW DESCRIPTION FIELD -->
      <textarea
        name="description"
        placeholder="Enter Description"
        required
        class="w-full px-4 py-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
      ><%= editing ? home.description : '' %></textarea>

      <button
        type="submit"
        class="w-full bg-red-500 text-white py-2 rounded-md hover:bg-red-600 transition duration-300"
      >
        <%= editing ? 'Update Home' : 'Add Home' %>
      </button>

    </form>

  </main>

</body>
</html>